{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", ".source/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "types:check": {
      "dependsOn": ["^types:check"]
    },
    "lint": {}
  }
}
